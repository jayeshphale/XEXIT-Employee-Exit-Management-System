# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: The MongoDB connection string for persistent storage.
# The app falls back gracefully to a fully pre-seeded in-memory mock store if this is omitted.
MONGODB_URI="mongodb+srv://..."

# JWT_SECRET: Secret key for signing/verifying JWT authentication tokens.
JWT_SECRET="xexit-jwt-super-secret-key-987654"

# CALENDARIFIC_API_KEY: Optional Calendarific developer API key for accurate holiday validation.
# Validates selected last working dates against official state holidays.
CALENDARIFIC_API_KEY="MY_CALENDARIFIC_API_KEY"

# EMAIL_USER & EMAIL_PASS: Nodemailer Gmail authentication credentials.
# Enables real-time email notifications for resignation submission, approval, rejection, and updates.
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-gmail-app-password"

# VITE_API_BASE_URL: Backend api URL used when frontend is deployed separate from backend.
# Leave blank when served from the same server (e.g., Express + Vite SPA bundle).
VITE_API_BASE_URL=""
